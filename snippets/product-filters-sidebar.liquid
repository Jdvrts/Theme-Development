{%- comment -%}
	------------------------------------------------------------------------------
	Snippet: Product filters sidebar
	- product_list: Collection or Search object (required)
	- filter_type: filter type (sidebar/top-bar/drawer) (required)
	- show_swatches: boolean. Set true to show swatches instead of checkbox

	Usage:

	{%- render 'product-filters-sidebar', product_list: product_list, filter_type: 'sidebar' -%}
	or
	{%- render 'product-filters-sidebar', product_list: product_list, filter_type: 'sidebar' -%}
	------------------------------------------------------------------------------
{%- endcomment -%}

{%- if template.name == 'collection' -%}
	{%- assign count = product_list.products_count -%}
{%- elsif template.name == 'search' -%}
	{%- assign count = product_list.results_count -%}
{%- endif -%}

{%- assign id = filter_type -%}

{%- if product_list != blank -%}
	<div class="product-filters product-filters--sidebar">
		<form class="product-filters__form js-form">
			<div class="product-filters__form-body">
				{%- render 'product-filters-selected', product_list: product_list, filter_type: 'sidebar' -%}

				<div
					class="accordion product-filters__form-accordion js-accordion-container js-filters-container"
					id="filters-container-{{ section.id }}-{{ filter.param_name | escape }}-{{ section.id }}-{{- id -}}"
				>
					{%- assign filterListIndex = 1 -%}

					{%- for filter in product_list.filters -%}
						{%- if filter.type == 'list' and filter.values.size == 0 or filter.type == 'boolean' and filter.values.size == 0 -%}
							{%- continue -%}
						{%- endif -%}

						<div
							id="filter-{{ section.id }}-{{ filter.param_name | escape }}-{{- id -}}"
							class="accordion__item product-filters__form-item js-accordion-item js-filter-item"
						>
							<h3 class="accordion__title">
								<button
									class="focus-visible-outline accordion__control product-filters__form-item-toggle-button js-accordion-control"
									type="button"
									id="Filter-accordion-{{ section.id }}-{{- filterListIndex -}}-{{- id -}}"
									aria-controls="filter-list-{{ section.id }}-{{- filterListIndex -}}-{{- id -}}"
									aria-expanded="false"
								>
									<span typeof="product-filters__form-item-toggle-title">
										{{- filter.label -}}

										<span class="js-filter-item-counter">
											{%- if filter.active_values.size > 0 and filter.type != 'price_range' -%}
												&nbsp;({{- filter.active_values.size -}})
											{%- endif -%}
										</span>
									</span>
									{%- render 'icons', icon: 'arrow-down' -%}
								</button>
							</h3>

							<div
								class="accordion__content accordion__content--animate js-accordion-content"
								id="filter-list-{{ section.id }}-{{- filterListIndex -}}-{{- id -}}"
								aria-labelledby="Filter-accordion-{{ section.id }}-{{- filterListIndex -}}-{{- id -}}"
								role="region"
								style="height: 0;"
							>
								<div class="js-accordion-inner product-filters__form-item-content">
									{%- case filter.type -%}
										{%- when 'list' or 'boolean' -%}
											{% if filter.operator == "AND" %}
												<span class="product-filters__form-helptext">
													{{- 'general.filters.filter_and_operator_subtitle' | t -}}
												</span>
											{% endif %}

											{%- render 'filter-list', filter: filter, show_swatches: show_swatches, filter_type: 'sidebar', id: id -%}
										{%- when 'price_range' -%}
											{%- render 'filter-price', filter: filter, id: id -%}
									{%- endcase -%}
								</div>
							</div>

							{%- assign filterListIndex = filterListIndex | plus: 1 -%}
						</div>
					{%- endfor -%}
				</div>
			</div>
		</form>
	</div>
{%- endif -%}
