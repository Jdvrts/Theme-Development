{%- comment -%}
------------------------------------------------------------------------------
	Section: Footer
------------------------------------------------------------------------------
{%- endcomment -%}

{%- render 'adastra' with '/src/styles/footer.scss' -%}

{%- assign logo_image		    	= section.settings.logo_image -%}
{%- assign logo_image_width	    	= section.settings.logo_image_width -%}

{%- assign copyright_text			= section.settings.copyright_text -%}
{%- assign default_success_text     = 'newsletter.success' | t -%}
{%- assign current_year				= 'now' | date: '%Y'  -%}

{%- assign is_show_country_selector  = section.settings.is_show_country_selector -%}
{%- assign is_show_language_selector = section.settings.is_show_language_selector -%}
{%- assign is_show_payment_methods   = section.settings.is_show_payment_methods -%}
{%- assign show_back_to_top_button	 = section.settings.show_back_to_top_button -%}
{%- assign show_store_policies_in_footer = section.settings.show_store_policies_in_footer -%}

{%- assign color_scheme                    = section.settings.color_scheme -%}
{%- assign enable_color_scheme_inheritance = section.settings.enable_color_scheme_inheritance -%}

{%- assign refund_policy 		= shop.refund_policy -%}
{%- assign privacy_policy 		= shop.privacy_policy -%}
{%- assign terms_of_service 	= shop.terms_of_service -%}
{%- assign shipping_policy 		= shop.shipping_policy -%}
{%- assign legal_notice 		= shop.legal_notice -%}

{%- if enable_color_scheme_inheritance -%}
	{%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- capture section_styles -%}
	--logo-image-width: {{ logo_image_width }}px;
{%- endcapture -%}

{%- capture newsletter -%}
	{%- assign newsletter_block = section.blocks | where: 'type', 'newsletter' | first -%}

	{%- if newsletter_block != blank -%}
		{%- assign newsletter_heading = newsletter_block.settings.heading -%}
		{%- assign newsletter_text = newsletter_block.settings.text -%}
		{%- assign newsletter_input_placeholder = newsletter_block.settings.input_placeholder -%}
		{%- assign newsletter_button_label = newsletter_block.settings.button_label -%}
		{%- assign newsletter_success_message = newsletter_block.settings.success_message -%}

		{%- if newsletter_heading != blank -%}
			<h2 class="footer__newsletter-heading h4">
				{{- newsletter_heading -}}
			</h2>
		{%- endif -%}

		{%- if newsletter_text != blank -%}
			<p class="footer__newsletter-text">
				{{- newsletter_text -}}
			</p>
		{%- endif -%}

		{%- assign id = 'footerForm--' | append: section.id -%}

		{%- form 'customer', class: 'footer-form js-newsletter-form', id: id -%}
			<input type="hidden" name="contact[tags]" value="newsletter"/>

			<div class="footer-form__field">
				<label class="visually-hidden" for="NewsletterForm--{{- section.id -}}">
					{{- newsletter_input_placeholder -}}
				</label>

				<input
					id="NewsletterForm--{{- section.id -}}"
					type="email"
					name="contact[email]"
					class="footer-form__input input js-newsletter-input"
					value="{{- form.email -}}"
					aria-required="true"
					autocapitalize="off"
					autocomplete="email"
					{% if form.errors %}
						aria-invalid="true"
						aria-describedby="Newsletter-error--{{- section.id -}}"
					{% elsif form.posted_successfully? %}
						aria-describedby="Newsletter-success--{{- section.id -}}"
					{% endif %}
					placeholder="{{- newsletter_input_placeholder -}}"
					required
				/>

				<button type="submit" name="commit" class="button button--secondary button--block footer-form__button">
					<span data-text="{{- newsletter_button_label -}}">
						<span>{{- newsletter_button_label -}}</span>
					</span>
				</button>
			</div>

			{%- if form.errors -%}
				<small class="footer-form__message footer-form__message--error" id="Newsletter-error--{{- section.id -}}">
					{%- render 'icons', icon: 'menu-close' -%}

					{{- form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] -}}
				</small>
			{%- endif -%}

			{%- if form.posted_successfully? -%}
				<p
					class="footer-form__message footer-form__message--success"
					id="Newsletter-success--{{- section.id -}}"
					tabindex="-1"
				>
					{%- render 'icons', icon: 'check' -%}

					{{- newsletter_success_message -}}
				</p>
			{%- endif -%}
		{%- endform -%}
	{%- endif -%}
{%- endcapture -%}

{%- capture contact -%}
	{%- assign contact_block = section.blocks | where: 'type', 'contact' | first -%}

	{%- if contact_block != blank -%}
		{%- assign show_socials = contact_block.settings.show_socials -%}
		{%- assign heading = contact_block.settings.heading -%}
		{%- assign email_icon = contact_block.settings.email_icon -%}
		{%- assign email_text = contact_block.settings.email_text -%}
		{%- assign phone_icon = contact_block.settings.phone_icon -%}
		{%- assign phone_text = contact_block.settings.phone_text -%}
		{%- assign additional_icon = contact_block.settings.additional_icon -%}
		{%- assign additional_text = contact_block.settings.additional_text -%}

		{%- if heading != blank -%}
			<h2 class="footer__navigation-heading text">
				{{- heading -}}
			</h2>
		{%- endif -%}

		{%- if show_socials or email_text != blank or phone_text != blank or additional_text != blank -%}
			<ul class="footer__navigation-list">
				{%- if email_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ email_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if email_icon != blank -%}
							<img
								class="icon"
								src="{{ email_icon | image_url: width: 16 }}"
								srcset="{{ email_icon | image_url: width: 16 }} 1x,
										{{ email_icon | image_url: width: 32 }} 2x"
								alt="{{ email_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ email_text }}</div>
					</li>
				{%- endif -%}

				{%- if phone_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ phone_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if phone_icon != blank -%}
							<img
								class="icon"
								src="{{ phone_icon | image_url: width: 16 }}"
								srcset="{{ phone_icon | image_url: width: 16 }} 1x,
										{{ phone_icon | image_url: width: 32 }} 2x"
								alt="{{ phone_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ phone_text }}</div>
					</li>
				{%- endif -%}

				{%- if additional_text != blank -%}
					<li class="footer__navigation-list-item">
						{%- capture img_focal -%}
							--img-desktop-pos: {{ additional_icon.presentation.focal_point }};
						{%- endcapture -%}

						{%- if additional_icon != blank -%}
							<img
								class="icon"
								src="{{ additional_icon | image_url: width: 16 }}"
								srcset="{{ additional_icon | image_url: width: 16 }} 1x,
										{{ additional_icon | image_url: width: 32 }} 2x"
								alt="{{ additional_icon.alt | escape }}"
								width="16"
								height="16"
								style="{{ img_focal }}"
								loading="lazy"
								fetchpriority="low"
								decoding="async"
							/>
						{%- endif -%}

						<div class="rte">{{ additional_text }}</div>
					</li>
				{%- endif -%}

				{%- if show_socials -%}
					<li class="footer__navigation-list-item">
						{%- render 'social-links' -%}
					</li>
				{%- endif -%}
			</ul>
		{%- endif -%}
	{%- endif -%}
{%- endcapture -%}

{%- capture middle_content -%}
	{%- if is_show_country_selector == true and localization.available_countries.size > 1 -%}
		{%- assign country_selector = true -%}
	{%- endif -%}
	{%- if is_show_language_selector == true and localization.available_languages.size > 1 -%}
		{%- assign language_selector = true -%}
	{%- endif -%}

	{%- if country_selector or language_selector or shop.enabled_payment_types and is_show_payment_methods -%}
		<div class="footer__middle-container">
			{%- if country_selector or language_selector -%}
				<div class="footer__selectors">
					{%- if language_selector -%}
						{%- render 'language-localization-form', class: 'footer', id_prefix: 'footer', form_id: "FooterLocalizationForm" -%}
					{%- endif -%}

					{%- if country_selector -%}
						{%- render 'country-localization-form', class: 'footer', id_prefix: "footer", form_id: "FooterCountryForm" -%}
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if shop.enabled_payment_types and is_show_payment_methods -%}
				<ul class="footer__payments-container" aria-label="{{ 'general.payment.method' | t | escape }}">
					{%- for type in shop.enabled_payment_types -%}
						<li class="footer__payments-item">
							{{- type | payment_type_svg_tag: class: 'payment-icon' -}}
						</li>
					{% endfor %}
				</ul>
			{%- endif -%}
		</div>
	{%- endif -%}
{%- endcapture -%}

{%- capture logo_content -%}
	<div class="footer__logo-container">
		{%- if logo_image != blank -%}
			{%- assign logo_height = logo_image_width | divided_by: logo_image.aspect_ratio | round: 0 -%}
			{%- assign logo_width_x2 = logo_image_width | times: 2 -%}

			{%- capture img_focal -%}
				--img-desktop-pos: {{ logo_image.presentation.focal_point }};
			{%- endcapture -%}

			<a
				href="{{ routes.root_url }}"
				class="footer__logo-link focus-visible-outline"
				aria-label="{{ 'general.accessibility.link_messages.link_to_home_page' | t | escape }}"
			>
				<img
					class="footer__logo"
					src="{{ logo_image | image_url: width: logo_image_width }}"
					srcset="{{ logo_image | image_url: width: logo_image_width }} 1x,
						{{ logo_image | image_url: width: logo_width_x2 }} 2x"
					alt="{{ logo_image.alt | escape }}"
					width="{{ logo_image_width }}"
					height="{{ logo_height }}"
					style="{{ img_focal }}"
					loading="lazy"
					fetchpriority="low"
					decoding="async"
				/>
			</a>
		{%- endif -%}
	</div>
{% endcapture %}

<footer class="footer container color-{{ color_scheme }} need-animate js-animate" style="{{ section_styles }}">
	<div class="footer__main-content js-accordion-container">
		{% assign col_delay_step = 0 %}

		{%- for block in section.blocks -%}
			{% assign col_delay_step = col_delay_step | plus: 0.2 %}

			{%- if block.type == 'menu' -%}
				{%- assign menu         = block.settings.menu -%}
				{%- assign menu_heading = block.settings.menu_heading -%}

				{%- if menu != blank -%}
					<div class="footer__navigation-item footer__navigation-item--mobile accordion__item js-accordion-item" style="transition-delay: {{ col_delay_step }}s">
						{%- if menu_heading == blank -%}
							{%- assign menu_heading = linklists[menu].title -%}
						{%- endif -%}

						<h2 class="footer__navigation-heading h5 accordion__title">
							<button
								id="control-{{- block.id -}}"
								class="accordion__control footer__navigation-item-control js-accordion-control"
								aria-controls="content-{{- block.id -}}"
								aria-expanded="false"
							>
								{{ menu_heading }}

								{% render 'icons', icon: 'arrow-down' %}
							</button>
						</h2>

						<div
							id="content-{{- block.id -}}"
							class="accordion__content accordion__content--animate js-accordion-content"
							style="height: 0;"
							role="region"
							aria-labelledby="control-{{- block.id -}}"
						>
							<ul class="footer__navigation-list js-accordion-inner">
								{%- for link in linklists[menu].links -%}
									<li class="footer__navigation-list-item">
										<a href="{{ link.url }}" class="footer__navigation-list-link button-link">
											<span data-text="{{ link.title }}">
												<span>{{ link.title }}</span>
											</span>
										</a>
									</li>
								{%- endfor -%}
							</ul>
						</div>
					</div>

					<div class="footer__navigation-item footer__navigation-item--desktop" style="transition-delay: {{ col_delay_step }}s">
						{%- if menu_heading == blank -%}
							{%- assign menu_heading = linklists[menu].title -%}
						{%- endif -%}

						<h2 class="footer__navigation-heading text">
							{{ menu_heading }}
						</h2>

						<ul class="footer__navigation-list">
							{%- for link in linklists[menu].links -%}
								<li class="footer__navigation-list-item">
									<a href="{{ link.url }}" class="footer__navigation-list-link button-link">
										<span data-text="{{ link.title }}">
											<span>{{ link.title }}</span>
										</span>
									</a>
								</li>
							{%- endfor -%}
						</ul>
					</div>
				{%- endif -%}
			{%- endif -%}

			{%- if block.type == 'contact' and contact != blank -%}
				<div class="footer__navigation-item footer__navigation-item--contact {% if forloop.first %}footer__navigation-item--contact-first{% endif %} {% if forloop.first == false and forloop.last == false %}footer__navigation-item--contact-middle{% endif %}" style="transition-delay: {{ col_delay_step }}s">
					{{- contact -}}
				</div>
			{%- endif -%}

			{%- if block.type == 'newsletter' and newsletter != blank -%}
				<div class="footer__newsletter" style="transition-delay: {{ col_delay_step }}s">
					{{- newsletter -}}
				</div>
			{%- endif -%}
		{%- endfor -%}
	</div>

	<div class="footer__bottom-content-wrapper" style="transition-delay: {{ section.blocks.size | plus: 1 | times: 0.2 }}s">
		{{- middle_content -}}

		{{- logo_content -}}

		{%- if show_store_policies_in_footer -%}
			{%- if refund_policy or privacy_policy or terms_of_service or shipping_policy or legal_notice -%}
				<ul class="footer__policy-list">
					{%- if refund_policy != blank -%}
						<li class="footer__policy-list-item">
							<a href="{{ refund_policy.url }}" class="button-link">
									<span data-text="{{ refund_policy.title }}">
										<span>{{ refund_policy.title }}</span>
									</span>
							</a>
						</li>
					{%- endif -%}

					{%- if privacy_policy != blank -%}
						<li class="footer__policy-list-item">
							<a href="{{ privacy_policy.url }}" class="button-link">
							<span data-text="{{ privacy_policy.title }}">
								<span>{{ privacy_policy.title }}</span>
							</span>
							</a>
						</li>
					{%- endif -%}

					{%- if terms_of_service != blank -%}
						<li class="footer__policy-list-item">
							<a href="{{ terms_of_service.url }}" class="button-link">
							<span data-text="{{ terms_of_service.title }}">
								<span>{{ terms_of_service.title }}</span>
							</span>
							</a>
						</li>
					{%- endif -%}

					{%- if shipping_policy != blank -%}
						<li class="footer__policy-list-item">
							<a href="{{ shipping_policy.url }}" class="button-link">
							<span data-text="{{ shipping_policy.title }}">
								<span>{{ shipping_policy.title }}</span>
							</span>
							</a>
						</li>
					{%- endif -%}

					{%- if legal_notice != blank -%}
						<li class="footer__policy-list-item">
							<a href="{{ legal_notice.url }}" class="button-link">
							<span data-text="{{ legal_notice.title }}">
								<span>{{ legal_notice.title }}</span>
							</span>
							</a>
						</li>
					{%- endif -%}
				</ul>
			{%- endif -%}
		{%- endif -%}

		<div class="footer__bottom-content">
			<p class="footer__copyright">
				{{ copyright_text | replace: "%date%", current_year }}
			</p>

			<span class="footer__bottom-divider">|</span>

			{{ powered_by_link }}

			{%- if show_back_to_top_button == true -%}
				<button class="footer__back-to-top button-social js-back-to-top-button" type="button" aria-label="{{ 'general.accessibility.scroll_to_top' | t | escape }}">
					{%- render 'icons', icon: 'slider-arrow-up' -%}
				</button>
			{%- endif -%}
		</div>

		{%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
			{{ shop | login_button: action: 'follow' }}
		{%- endif -%}
	</div>
</footer>

{% schema %}
{
	"name": "Footer",
	"settings": [
		{
			"type": "header",
			"content": "Logo"
		},
		{
			"id": "logo_image",
			"type": "image_picker",
			"label": "Logo image"
		},
		{
			"id": "logo_image_width",
			"type": "range",
			"min": 50,
			"max": 450,
			"step": 10,
			"unit": "px",
			"label": "Logo width",
			"default": 320
		},
		{
			"type": "textarea",
			"id": "copyright_text",
			"label": "Copyright text",
			"default": "Copyright © %date%.",
			"info": "%date% - will be replaced with the current year"
		},
		{
			"id": "is_show_payment_methods",
			"type": "checkbox",
			"label": "Show payment icons",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "show_back_to_top_button",
			"label": "Show back to top button",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "show_store_policies_in_footer",
			"label": "Show Store Policies in Footer",
			"default": false
		},
		{
			"type": "header",
			"content": "COUNTRY/REGION SELECTOR"
		},
		{
			"id": "is_show_country_selector",
			"type": "checkbox",
			"label": "Show country/region selector",
			"default": true
		},
		{
			"type": "header",
			"content": "LANGUAGE SELECTOR"
		},
		{
			"id": "is_show_language_selector",
			"type": "checkbox",
			"label": "Show language selector",
			"default": true
		},
		{
			"type": "header",
			"content": "FOLLOW ON SHOP"
		},
		{
			"type": "checkbox",
			"id": "enable_follow_on_shop",
			"label": "Enable Follow on Shop",
			"default": true
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "checkbox",
			"id": "enable_color_scheme_inheritance",
			"label": "Enable color scheme inheritance",
			"default": true,
			"info": "When this setting is enabled, the color scheme is inherited from the theme settings."
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"label": "Color scheme",
			"default": "scheme-1"
		}
	],
	"blocks": [
		{
			"type": "menu",
			"name": "Footer menu",
			"limit": 3,
			"settings": [
				{
					"id": "menu_heading",
					"type": "text",
					"label": "Heading"
				},
				{
					"id": "menu",
					"type": "link_list",
					"label": "Menu",
					"info": "Displays only top-level menu items.",
					"default": "footer"
				}
			]
		},
		{
			"type": "contact",
			"name": "Footer contact",
			"limit": 1,
			"settings": [
				{
					"type": "checkbox",
					"id": "show_socials",
					"label": "Show socials",
					"default": true
				},
				{
					"type": "text",
					"id": "heading",
					"label": "Heading"
				},
				{
					"type": "header",
					"content": "Email"
				},
				{
					"type": "image_picker",
					"id": "email_icon",
					"label": "Icon"
				},
				{
					"type": "inline_richtext",
					"id": "email_text",
					"label": "Text"
				},
				{
					"type": "header",
					"content": "Phone"
				},
				{
					"type": "image_picker",
					"id": "phone_icon",
					"label": "Icon"
				},
				{
					"type": "inline_richtext",
					"id": "phone_text",
					"label": "Text"
				},
				{
					"type": "header",
					"content": "Additional information"
				},
				{
					"type": "image_picker",
					"id": "additional_icon",
					"label": "Icon"
				},
				{
					"type": "inline_richtext",
					"id": "additional_text",
					"label": "Text"
				}
			]
		},
		{
			"type": "newsletter",
			"name": "Footer newsletter",
			"limit": 1,
			"settings": [
				{
					"type": "text",
					"id": "heading",
					"label": "Heading",
					"default": "Newsletter"
				},
				{
					"type": "textarea",
					"id": "text",
					"label": "Text"
				},
				{
					"type": "text",
					"id": "input_placeholder",
					"label": "Input placeholder",
					"default": "Enter email address..."
				},
				{
					"type": "text",
					"id": "button_label",
					"label": "Button label",
					"default": "Subscribe"
				},
				{
					"type": "text",
					"id": "success_message",
					"label": "Success message",
					"default": "Thanks for subscribing"
				}
			]
		}
	]
}
{% endschema %}
