{% doc %}
  @prompt
    Based on ai_gen_block_1fc1383.liquid make a new block with same buttons and menus - add an option for me to decide which menu will be shown in this block.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-menu-buttons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-menu-buttons__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.button_gap }}px;
    justify-content: {{ block.settings.alignment }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-menu-buttons__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    text-transform: {% if block.settings.button_uppercase %}uppercase{% else %}none{% endif %};
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-menu-buttons__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-menu-buttons__container-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
      gap: {{ block.settings.mobile_button_gap }}px;
    }

    .ai-menu-buttons__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<menu-buttons-{{ ai_gen_id }}
  class="ai-menu-buttons-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-menu-buttons__container-{{ ai_gen_id }}">
    {% if block.settings.selected_menu != blank %}
      {% assign menu = linklists[block.settings.selected_menu] %}
      {% if menu.links.size > 0 %}
        {% for link in menu.links %}
          <a
            href="{{ link.url }}"
            class="ai-menu-buttons__button-{{ ai_gen_id }}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {% endfor %}
      {% else %}
        <div style="padding: 20px; text-align: center; color: #999; font-style: italic;">
          The selected menu has no links. Add links to your menu in Navigation settings.
        </div>
      {% endif %}
    {% else %}
      <div style="padding: 20px; text-align: center; color: #999; font-style: italic;">
        Next, select a menu to display
      </div>
    {% endif %}
  </div>
</menu-buttons-{{ ai_gen_id }}>

<script>
  (function() {
    class MenuButtons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-menu-buttons__button-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.buttons.forEach((button) => {
          button.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              button.click();
            }
          });
        });
      }
    }

    customElements.define('menu-buttons-{{ ai_gen_id }}', MenuButtons{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
