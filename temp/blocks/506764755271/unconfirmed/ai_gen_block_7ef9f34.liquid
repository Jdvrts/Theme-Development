{% doc %}
  @prompt
    Make a selection with z index 2 that will house menu and search button for mobile view only. The section being fixed to bottom of the screen at all times.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-nav-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 2;
    background-color: {{ block.settings.background_color }};
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    box-shadow: 0 -2px 10px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-mobile-nav-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-mobile-nav-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-around;
    align-items: center;
    max-width: 100%;
    margin: 0 auto;
    gap: {{ block.settings.button_gap }}px;
  }

  .ai-mobile-nav-button-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: {{ block.settings.button_padding }}px;
    flex: 1;
    max-width: 200px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: {{ block.settings.icon_color }};
  }

  .ai-mobile-nav-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.icon_hover_color }};
    background-color: {{ block.settings.button_hover_background }};
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-mobile-nav-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_label_gap }}px;
  }

  .ai-mobile-nav-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-mobile-nav-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
    color: currentColor;
    text-align: center;
  }
{% endstyle %}

<mobile-nav-{{ ai_gen_id }} class="ai-mobile-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-nav-container-{{ ai_gen_id }}">
    {% if block.settings.show_menu_button %}
      <button
        class="ai-mobile-nav-button-{{ ai_gen_id }}"
        aria-label="{{ block.settings.menu_label }}"
        data-action="menu"
      >
        <span class="ai-mobile-nav-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </span>
        {% if block.settings.show_labels %}
          <span class="ai-mobile-nav-label-{{ ai_gen_id }}">{{ block.settings.menu_label }}</span>
        {% endif %}
      </button>
    {% endif %}

    {% if block.settings.show_search_button %}
      <button
        class="ai-mobile-nav-button-{{ ai_gen_id }}"
        aria-label="{{ block.settings.search_label }}"
        data-action="search"
      >
        <span class="ai-mobile-nav-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </span>
        {% if block.settings.show_labels %}
          <span class="ai-mobile-nav-label-{{ ai_gen_id }}">{{ block.settings.search_label }}</span>
        {% endif %}
      </button>
    {% endif %}
  </div>
</mobile-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class MobileNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.menuButton = this.querySelector('[data-action="menu"]');
        this.searchButton = this.querySelector('[data-action="search"]');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.menuButton) {
          this.menuButton.addEventListener('click', () => {
            const menuDrawer = document.querySelector('menu-drawer');
            if (menuDrawer) {
              menuDrawer.open(this.menuButton);
            } else {
              const mobileMenu = document.querySelector('.mobile-menu');
              if (mobileMenu) {
                mobileMenu.classList.toggle('active');
              }
            }
          });
        }

        if (this.searchButton) {
          this.searchButton.addEventListener('click', () => {
            const searchModal = document.querySelector('details-modal[id*="Search"]');
            if (searchModal) {
              searchModal.show(this.searchButton);
            } else {
              const searchForm = document.querySelector('.search-modal');
              if (searchForm) {
                searchForm.classList.toggle('active');
              } else {
                const headerSearch = document.querySelector('header [role="search"]');
                if (headerSearch) {
                  const searchInput = headerSearch.querySelector('input[type="search"]');
                  if (searchInput) {
                    searchInput.focus();
                  }
                }
              }
            }
          });
        }
      }
    }

    customElements.define('mobile-nav-{{ ai_gen_id }}', MobileNav{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Mobile bottom nav",
  "tag": null,
  "settings": [
